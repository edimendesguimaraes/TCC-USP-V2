{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "api/Auth/{**catch-all}",
          "Headers": []
        }
      },
      "usuarios-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "api/Usuarios/{**catch-all}"
        }
      },
      "ocorrencias-route": {
        "ClusterId": "ocorrencias-cluster",
        "Match": {
          "Path": "api/Ocorrencias/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5079"
          }
        }
      },
      "ocorrencias-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5260"
          }
        }
      }
    }
  }
}